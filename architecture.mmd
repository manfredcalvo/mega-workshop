  "theme": "base",
  "themeVariables": {
    "background":           "#0E1F27",
    "primaryColor":         "#3D2000",
    "primaryTextColor":     "#FFFFFF",
    "primaryBorderColor":   "#F6C000",
    "lineColor":            "#78909C",
    "secondaryColor":       "#002028",
    "tertiaryColor":        "#0D2229",
